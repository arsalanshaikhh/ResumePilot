# ResumePilot Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED - Authentication
# ============================================================================

# Clerk Authentication (get from https://clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ============================================================================
# OPTIONAL - API Configuration
# ============================================================================

# OpenRouter API for AI features (get from https://openrouter.ai)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# OPTIONAL - Application Settings
# ============================================================================

# Application Name (default: ResumePilot)
VITE_APP_NAME=ResumePilot

# Application Version (default: 1.0.0)
VITE_APP_VERSION=1.0.0

# API Timeout in milliseconds (default: 30000)
VITE_API_TIMEOUT=30000

# Enable debug mode (default: false)
VITE_DEBUG_MODE=false
